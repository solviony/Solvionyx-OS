<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkWindow" id="window">
    <property name="title">Welcome to Solvionyx OS</property>
    <property name="default-width">900</property>
    <property name="default-height">600</property>

    <child>
      <object class="GtkBox" id="root">
        <property name="orientation">vertical</property>
        <property name="spacing">20</property>

        <child>
          <object class="GtkImage" id="banner">
            <property name="file">/usr/share/solvionyx/welcome/banner.png</property>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="title">
            <property name="label">&lt;b&gt;&lt;span size='xx-large'&gt;Welcome to Solvionyx OS — Aurora&lt;/span&gt;&lt;/b&gt;</property>
            <property name="use-markup">true</property>
          </object>
        </child>

        <child>
          <object class="GtkLabel" id="subtitle">
            <property name="label">&lt;span foreground='#A9A9A9'&gt;The Engine Behind the Vision.&lt;/span&gt;</property>
            <property name="use-markup">true</property>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>

